<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Mostra apenas WARN/ERROR do Micronaut internals -->
    <logger name="io.micronaut" level="WARN"/>
    <logger name="io.netty" level="WARN"/>

    <!-- Mostra INFO do seu código e do startup -->
    <logger name="br.puc" level="DEBUG"/>
    <logger name="io.micronaut.runtime" level="INFO"/>
    <logger name="io.micronaut.http.server" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
